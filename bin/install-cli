#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
INSTALL_DIR="${1:-$HOME/.local/bin}"
TARGET_BIN="${INSTALL_DIR}/basalt"
LAUNCHER_BIN="${ROOT_DIR}/bin/basalt"
BUNDLE_BIN="${ROOT_DIR}/src-tauri/target/release/bundle/macos/Basalt.app/Contents/MacOS/Basalt"
RELEASE_BIN="${ROOT_DIR}/src-tauri/target/release/basalt"

mkdir -p "${INSTALL_DIR}"

echo "Building Tauri app bundle..."
(
  cd "${ROOT_DIR}"
  npm run tauri build
)

if [[ ! -x "${BUNDLE_BIN}" && ! -x "${RELEASE_BIN}" ]]; then
  echo "No runnable Basalt executable found after build." >&2
  exit 1
fi

ln -sf "${LAUNCHER_BIN}" "${TARGET_BIN}"

echo "Installed: ${TARGET_BIN}"
if ! command -v basalt >/dev/null 2>&1; then
  echo "Add ${INSTALL_DIR} to PATH to use 'basalt' globally."
fi
