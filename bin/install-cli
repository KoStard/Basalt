#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
INSTALL_DIR="${1:-$HOME/.local/bin}"
TARGET_BIN="${INSTALL_DIR}/basalt"
RELEASE_BIN="${ROOT_DIR}/src-tauri/target/release/basalt"

mkdir -p "${INSTALL_DIR}"

if ! command -v cargo >/dev/null 2>&1; then
  echo "cargo is required to build Basalt." >&2
  exit 1
fi

echo "Building frontend assets..."
(
  cd "${ROOT_DIR}"
  npm run build
)

echo "Building release binary..."
cargo build --release --manifest-path "${ROOT_DIR}/src-tauri/Cargo.toml"

if [[ ! -x "${RELEASE_BIN}" ]]; then
  echo "No runnable Basalt executable found after build." >&2
  exit 1
fi

install -m 755 "${RELEASE_BIN}" "${TARGET_BIN}"

echo "Installed: ${TARGET_BIN}"
if ! command -v basalt >/dev/null 2>&1; then
  echo "Add ${INSTALL_DIR} to PATH to use 'basalt' globally."
fi
